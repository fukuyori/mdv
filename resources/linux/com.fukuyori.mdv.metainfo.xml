  <name>mdv</name>
  <summary>Simple Markdown viewer/editor</summary>
  <description>
    <p>
      mdv is a lightweight Markdown viewer and editor with a live WebEngine
      preview. It supports synchronized scrolling between the editor and the
      rendered output, find and replace, and opening files from the command
      line or the desktop.
    </p>
  </description>
  <launchable type="desktop-id">mdv.desktop</launchable>
  <provides>
    <binary>mdv</binary>
  </provides>
